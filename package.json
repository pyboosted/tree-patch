{
  "name": "@hexie/tree-patch",
  "version": "0.1.0",
  "description": "Immutable, conflict-aware semantic patches for tree-shaped content.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyboosted/tree-patch.git"
  },
  "bugs": {
    "url": "https://github.com/pyboosted/tree-patch/issues"
  },
  "homepage": "https://github.com/pyboosted/tree-patch#readme",
  "keywords": [
    "tree",
    "patch",
    "diff",
    "rebase",
    "localization",
    "cms",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node --eval \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\" && tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.typecheck.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
